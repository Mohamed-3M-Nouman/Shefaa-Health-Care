@{
    ViewData["Title"] = "لوحة تحكم الطبيب";
}

<div class="container py-5">
    
    <!-- Welcome Header -->
    <div class="d-flex align-items-center mb-4 pb-3 border-bottom">
        <div class="rounded-circle bg-success bg-opacity-10 d-flex align-items-center justify-content-center me-3" style="width: 60px; height: 60px;">
            <i class="bi bi-person-badge-fill text-success fs-2"></i>
        </div>
        <div>
            <h2 class="fw-bold mb-1">مرحباً د. أحمد</h2>
            <p class="text-muted mb-0">نظرة عامة على مواعيدك وجدول عملك</p>
        </div>
    </div>

    <div class="row g-4">
        
        <!-- 1. Today's Appointments -->
        <div class="col-lg-7">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h5 class="fw-bold mb-0">مواعيد اليوم</h5>
                <span class="badge bg-success rounded-pill px-3 py-2">3 مواعيد متبقية</span>
            </div>

            <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="py-3 px-4">اسم المريض</th>
                                <th class="py-3">الوقت</th>
                                <th class="py-3">النوع</th>
                                <th class="py-3 text-center">إجراء</th>
                            </tr>
                        </thead>
                        <tbody>
                            <!-- Appt 1 -->
                            <tr>
                                <td class="py-3 px-4">
                                    <div class="fw-bold">محمد علي</div>
                                    <div class="small text-muted">متابعة دورية</div>
                                </td>
                                <td class="py-3">
                                    <span class="badge bg-danger bg-opacity-10 text-danger rounded-pill px-3">10:30 ص</span>
                                </td>
                                <td class="py-3">كشف جديد</td>
                                <td class="py-3 text-center">
                                    <button class="btn btn-sm btn-success rounded-pill px-3 fw-medium">
                                        <i class="bi bi-play-circle me-1"></i>بدء الكشف
                                    </button>
                                </td>
                            </tr>
                            <!-- Appt 2 -->
                            <tr>
                                <td class="py-3 px-4">
                                    <div class="fw-bold">سارة حسن</div>
                                    <div class="small text-muted">استشارة طبية</div>
                                </td>
                                <td class="py-3">
                                    <span class="badge bg-secondary bg-opacity-10 text-secondary rounded-pill px-3">12:00 م</span>
                                </td>
                                <td class="py-3">إعادة كشف</td>
                                <td class="py-3 text-center">
                                    <button class="btn btn-sm btn-outline-success rounded-pill px-3 fw-medium">
                                        <i class="bi bi-calendar-check me-1"></i>التفاصيل
                                    </button>
                                </td>
                            </tr>
                            <!-- Appt 3 -->
                            <tr>
                                <td class="py-3 px-4">
                                    <div class="fw-bold">عمر فاروق</div>
                                    <div class="small text-muted">ألم في الصدر</div>
                                </td>
                                <td class="py-3">
                                    <span class="badge bg-secondary bg-opacity-10 text-secondary rounded-pill px-3">02:30 م</span>
                                </td>
                                <td class="py-3">كشف مستعجل</td>
                                <td class="py-3 text-center">
                                    <button class="btn btn-sm btn-outline-success rounded-pill px-3 fw-medium">
                                        <i class="bi bi-calendar-check me-1"></i>التفاصيل
                                    </button>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- 2. Schedule Management -->
        <div class="col-lg-5">
            <h5 class="fw-bold mb-4">إدارة جدول العمل</h5>
            
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-4">
                    <p class="text-muted small mb-4">حدد أيام العمل وساعات التواجد بالعيادة. سيتم تطبيق هذه الإعدادات على نظام الحجز المباشر.</p>
                    
                    <form>
                        <!-- Schedule Item 1 -->
                        <div class="d-flex align-items-center justify-content-between mb-3 pb-3 border-bottom">
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" id="day1" checked>
                                <label class="form-check-label fw-bold ms-2" for="day1">الأحد</label>
                            </div>
                            <div class="d-flex gap-2 align-items-center">
                                <input type="time" class="form-control form-control-sm border-0 bg-light rounded-3" value="10:00">
                                <span class="text-muted small">إلى</span>
                                <input type="time" class="form-control form-control-sm border-0 bg-light rounded-3" value="15:00">
                            </div>
                        </div>

                        <!-- Schedule Item 2 -->
                        <div class="d-flex align-items-center justify-content-between mb-3 pb-3 border-bottom">
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" id="day2" checked>
                                <label class="form-check-label fw-bold ms-2" for="day2">الثلاثاء</label>
                            </div>
                            <div class="d-flex gap-2 align-items-center">
                                <input type="time" class="form-control form-control-sm border-0 bg-light rounded-3" value="12:00">
                                <span class="text-muted small">إلى</span>
                                <input type="time" class="form-control form-control-sm border-0 bg-light rounded-3" value="18:00">
                            </div>
                        </div>

                        <!-- Schedule Item 3 -->
                        <div class="d-flex align-items-center justify-content-between mb-4 pb-3 border-bottom">
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" id="day3">
                                <label class="form-check-label text-muted ms-2" for="day3">الجمعة (مغلق)</label>
                            </div>
                            <div class="d-flex gap-2 align-items-center opacity-50 pe-none">
                                <input type="time" class="form-control form-control-sm border-0 bg-light rounded-3">
                                <span class="text-muted small">إلى</span>
                                <input type="time" class="form-control form-control-sm border-0 bg-light rounded-3">
                            </div>
                        </div>

                        <button type="button" class="btn btn-success w-100 rounded-pill fw-medium py-2">
                            <i class="bi bi-save me-2"></i>حفظ التعديلات
                        </button>
                    </form>
                </div>
            </div>
        </div>

    </div>
</div>
