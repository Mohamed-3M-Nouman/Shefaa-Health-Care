@model IEnumerable<ShefaaHealthCare.Models.Doctor>
@using ShefaaHealthCare.Models

@{
    ViewData["Title"] = "ابحث عن الأطباء";
}

<!-- ══════════════════════════════════════════ -->
<!--  SEARCH & FILTER SECTION                   -->
<!-- ══════════════════════════════════════════ -->
<section class="py-5 bg-success bg-opacity-10">
    <div class="container">
        <div class="text-center mb-5">
            <h1 class="fw-bold text-dark mb-3">ابحث عن الطبيب المناسب</h1>
            <p class="text-muted fs-5">اختر من قائمة الأطباء المتخصصين والمعتمدين</p>
        </div>

        <!-- Search Form -->
        <form method="get" asp-action="Index" class="row g-3 mb-5">
            <div class="col-md-6">
                <input type="text" name="search" class="form-control form-control-lg rounded-3"
                       placeholder="ابحث عن طبيب أو تخصص..."
                       value="@ViewBag.Search" />
            </div>
            <div class="col-md-4">
                <select name="specializationId" class="form-select form-select-lg rounded-3">
                    <option value="">كل التخصصات</option>
                    @foreach (var spec in (IEnumerable<Specialization>)ViewBag.Specializations ?? new List<Specialization>())
                    {
                        <option value="@spec.Id" selected="@(ViewBag.SelectedSpecialization == spec.Id)">
                            @spec.Name
                        </option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-success btn-lg w-100 rounded-3">
                    <i class="bi bi-search me-1"></i>بحث
                </button>
            </div>
        </form>
    </div>
</section>

<!-- ══════════════════════════════════════════ -->
<!--  DOCTORS LIST                              -->
<!-- ══════════════════════════════════════════ -->
<section class="py-5">
    <div class="container">
        @if (Model.Any())
        {
            <div class="row g-4">
                @foreach (var doctor in Model)
                {
                    <div class="col-md-6 col-lg-4">
                        <div class="card h-100 shadow-sm rounded-4 overflow-hidden hover-shadow transition"
                             style="border: none;">
                            <!-- Doctor Header -->
                            <div class="bg-success bg-opacity-10 p-4 text-center">
                                <div class="rounded-circle bg-success bg-opacity-25 d-inline-flex align-items-center justify-content-center"
                                     style="width:80px;height:80px">
                                    <i class="bi bi-person-circle text-success" style="font-size:3rem"></i>
                                </div>
                                <h5 class="fw-bold mt-3 text-dark">@doctor.FullName</h5>
                                <p class="text-success fw-500 mb-0">
                                    <i class="bi bi-tag me-1"></i>@doctor.Specialization?.Name
                                </p>
                            </div>

                            <!-- Doctor Info -->
                            <div class="card-body">
                                <!-- Verification Badge -->
                                <div class="mb-3">
                                    <span class="badge bg-success bg-opacity-25 text-success rounded-3">
                                        <i class="bi bi-check-circle me-1"></i>معتمد ومتحقق
                                    </span>
                                </div>

                                <!-- Bio -->
                                @if (!string.IsNullOrEmpty(doctor.Bio))
                                {
                                    <p class="text-muted small mb-3">@doctor.Bio</p>
                                }

                                <!-- Fee -->
                                <div class="mb-3 pb-3 border-bottom">
                                    <small class="text-muted">رسوم الاستشارة</small>
                                    <h6 class="fw-bold text-success mb-0">
                                        @doctor.ConsultationFee.ToString("C0")
                                    </h6>
                                </div>

                                <!-- Availability -->
                                @if (doctor.Schedules?.Any() == true)
                                {
                                    <div class="mb-3">
                                        <small class="text-muted d-block mb-2">أيام العمل</small>
                                        <div class="d-flex flex-wrap gap-2">
                                            @{
                                                var daysOfWeek = new[] { "الأحد", "الاثنين", "الثلاثاء", "الأربعاء", "الخميس", "الجمعة", "السبت" };
                                                var availableDays = doctor.Schedules.Select(s => s.DayOfWeek).Distinct().OrderBy(d => d).ToList();
                                            }
                                            @foreach (var day in availableDays)
                                            {
                                                <span class="badge bg-success bg-opacity-10 text-success rounded-2">
                                                    @daysOfWeek[day]
                                                </span>
                                            }
                                        </div>
                                    </div>
                                }

                                <!-- Action Buttons -->
                                <div class="d-grid gap-2">
                                    <a asp-action="Profile" asp-route-id="@doctor.Id"
                                       class="btn btn-outline-success rounded-3 fw-500">
                                        <i class="bi bi-eye me-1"></i>عرض الملف الشخصي
                                    </a>
                                    @if (User.Identity?.IsAuthenticated == true)
                                    {
                                        <a href="#" class="btn btn-success rounded-3 fw-500">
                                            <i class="bi bi-calendar-check me-1"></i>احجز موعداً
                                        </a>
                                    }
                                    else
                                    {
                                        <a asp-controller="Account" asp-action="Login"
                                           class="btn btn-success rounded-3 fw-500">
                                            <i class="bi bi-calendar-check me-1"></i>احجز موعداً
                                        </a>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <!-- No Results -->
            <div class="text-center py-5">
                <div class="mb-4">
                    <i class="bi bi-search text-muted" style="font-size:4rem;opacity:0.3"></i>
                </div>
                <h5 class="text-muted fw-bold mb-2">لم يتم العثور على أطباء</h5>
                <p class="text-muted">
                    حاول البحث بكلمة أخرى أو اختر تخصصاً مختلفاً
                </p>
                <a asp-action="Index" class="btn btn-success btn-sm rounded-3 mt-3">
                    <i class="bi bi-arrow-repeat me-1"></i>إعادة تعيين البحث
                </a>
            </div>
        }
    </div>
</section>

<!-- ══════════════════════════════════════════ -->
<!--  CTA SECTION                               -->
<!-- ══════════════════════════════════════════ -->
@if (!User.Identity?.IsAuthenticated == true)
{
    <section class="py-5 bg-white border-top">
        <div class="container text-center">
            <h3 class="fw-bold mb-4">هل أنت طبيب؟</h3>
            <p class="text-muted mb-4">
                انضم إلى شبكة أطباء شفاء وتوسع قاعدة مرضاك
            </p>
            <a asp-controller="Account" asp-action="Register" class="btn btn-success btn-lg rounded-4">
                <i class="bi bi-person-plus me-2"></i>سجل كطبيب الآن
            </a>
        </div>
    </section>
}

<style>
    .hover-shadow {
        transition: all 0.3s ease;
    }
    .hover-shadow:hover {
        box-shadow: 0 12px 30px rgba(25, 135, 84, 0.15) !important;
        transform: translateY(-5px);
    }
</style>
