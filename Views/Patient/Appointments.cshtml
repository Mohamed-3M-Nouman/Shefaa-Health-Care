@model ShefaaHealthCare.Models.ViewModels.AppointmentListViewModel
@{
    ViewData["Title"] = "مواعيدي";
}

<div class="bg-success bg-opacity-10 py-4 border-bottom">
    <div class="container">
        <div class="d-flex align-items-center justify-content-between flex-wrap gap-3">
            <div>
                <h2 class="fw-bold mb-1">مواعيدي</h2>
                <p class="text-muted mb-0 small">عرض وإدارة جميع مواعيدك الطبية</p>
            </div>
            <a asp-controller="Doctor" asp-action="Index" class="btn btn-success rounded-pill px-4">
                <i class="bi bi-plus-lg me-1"></i>حجز موعد جديد
            </a>
        </div>
    </div>
</div>

<div class="container py-5">

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show rounded-4 shadow-sm border-0" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show rounded-4 shadow-sm border-0" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (Model.Appointments.Any())
    {
        <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0 text-center">
                    <thead class="table-light">
                        <tr>
                            <th class="py-3">التاريخ</th>
                            <th class="py-3">الطبيب</th>
                            <th class="py-3">التخصص</th>
                            <th class="py-3">سعر الكشف</th>
                            <th class="py-3">الحالة</th>
                            <th class="py-3">إجراءات</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var appt in Model.Appointments)
                        {
                            <tr class="@(appt.Status == "Cancelled" ? "table-light text-muted" : "")">
                                <td class="py-3">
                                    <span class="fw-bold">@appt.AppointmentDate.ToString("dd MMM yyyy")</span><br>
                                    <small class="text-muted">@appt.AppointmentDate.ToString("hh:mm tt")</small>
                                </td>
                                <td class="py-3 fw-bold">@appt.DoctorName</td>
                                <td class="py-3">@appt.SpecializationName</td>
                                <td class="py-3"><span class="badge bg-light text-dark border rounded-pill px-3 py-2">@appt.ConsultationFee ج.م</span></td>
                                <td class="py-3">
                                    @switch (appt.Status)
                                    {
                                        case "Confirmed":
                                            <span class="badge bg-success rounded-pill">مؤكد</span>
                                            break;
                                        case "Pending":
                                            <span class="badge bg-warning text-dark rounded-pill">قيد الانتظار</span>
                                            break;
                                        case "Completed":
                                            <span class="badge bg-info rounded-pill">مكتمل</span>
                                            break;
                                        case "Cancelled":
                                            <span class="badge bg-danger rounded-pill">ملغي</span>
                                            break;
                                        default:
                                            <span class="badge bg-secondary rounded-pill">@appt.Status</span>
                                            break;
                                    }
                                </td>
                                <td class="py-3">
                                    @if (appt.CanCancel)
                                    {
                                        <form asp-action="CancelAppointment" asp-route-id="@appt.Id" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill px-3"
                                                    onclick="return confirm('هل أنت متأكد من إلغاء هذا الموعد؟');">
                                                <i class="bi bi-x-circle me-1"></i>إلغاء
                                            </button>
                                        </form>
                                    }
                                    else if (appt.Status is "Cancelled" or "Completed")
                                    {
                                        <span class="text-muted small">—</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning bg-opacity-10 text-warning rounded-pill px-3 py-2" title="لا يمكن الإلغاء قبل أقل من 24 ساعة">
                                            <i class="bi bi-lock-fill me-1"></i>مغلق
                                        </span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body text-center py-5">
                <i class="bi bi-calendar-x text-muted mb-3" style="font-size: 4rem; opacity: 0.3;"></i>
                <h5 class="text-muted fw-bold">لا توجد مواعيد حتى الآن</h5>
                <p class="text-muted">ابدأ بحجز موعدك الأول مع أحد أطبائنا.</p>
                <a asp-controller="Doctor" asp-action="Index" class="btn btn-success rounded-pill px-4 mt-2">
                    <i class="bi bi-search me-1"></i>ابحث عن طبيب
                </a>
            </div>
        </div>
    }

    <div class="card border-0 bg-light rounded-4 mt-4">
        <div class="card-body p-3 d-flex flex-wrap gap-4 justify-content-center small">
            <span><i class="bi bi-circle-fill text-success me-1"></i>مؤكد</span>
            <span><i class="bi bi-circle-fill text-warning me-1"></i>قيد الانتظار</span>
            <span><i class="bi bi-circle-fill text-info me-1"></i>مكتمل</span>
            <span><i class="bi bi-circle-fill text-danger me-1"></i>ملغي</span>
            <span><i class="bi bi-lock-fill text-warning me-1"></i>أقل من 24 ساعة = غير قابل للإلغاء</span>
        </div>
    </div>
</div>
