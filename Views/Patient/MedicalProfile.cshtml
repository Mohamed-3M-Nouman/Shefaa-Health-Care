@model ShefaaHealthCare.Models.ViewModels.MedicalProfileViewModel
@{
    ViewData["Title"] = "الملف الطبي";
}

<div class="bg-success bg-opacity-10 py-4 border-bottom">
    <div class="container">
        <h2 class="fw-bold mb-1">الملف الطبي</h2>
        <p class="text-muted mb-0 small">تحديث بياناتك الصحية ورفع المرفقات الطبية</p>
    </div>
</div>

<div class="container py-5">

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show rounded-4 shadow-sm border-0" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show rounded-4 shadow-sm border-0" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row g-4">

        <!-- ══════════════════════════════════════════ -->
        <!--  Section A: Update Vitals / History       -->
        <!-- ══════════════════════════════════════════ -->
        <div class="col-lg-5">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-header bg-transparent border-0 pt-4 px-4 pb-0">
                    <h5 class="fw-bold mb-0"><i class="bi bi-heart-pulse me-2 text-success"></i>البيانات الصحية</h5>
                </div>
                <div class="card-body p-4">
                    <form asp-action="UpdateProfile" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="PatientId" />
                        <input type="hidden" asp-for="ProfileId" />

                        <div class="mb-3">
                            <label asp-for="BloodType" class="form-label fw-medium">فصيلة الدم</label>
                            <select asp-for="BloodType" class="form-select rounded-3">
                                <option value="">— اختر —</option>
                                <option value="A+">A+</option>
                                <option value="A-">A-</option>
                                <option value="B+">B+</option>
                                <option value="B-">B-</option>
                                <option value="AB+">AB+</option>
                                <option value="AB-">AB-</option>
                                <option value="O+">O+</option>
                                <option value="O-">O-</option>
                            </select>
                        </div>

                        <div class="mb-3">
                            <label asp-for="ChronicDiseases" class="form-label fw-medium">الأمراض المزمنة</label>
                            <textarea asp-for="ChronicDiseases" class="form-control rounded-3" rows="3" placeholder="مثال: ضغط دم مرتفع، سكري..."></textarea>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Allergies" class="form-label fw-medium">الحساسية</label>
                            <textarea asp-for="Allergies" class="form-control rounded-3" rows="3" placeholder="مثال: حساسية من البنسلين..."></textarea>
                        </div>

                        <div class="mb-4">
                            <label asp-for="FamilyHistory" class="form-label fw-medium">التاريخ العائلي</label>
                            <textarea asp-for="FamilyHistory" class="form-control rounded-3" rows="3" placeholder="مثال: تاريخ عائلي لأمراض القلب..."></textarea>
                        </div>

                        <button type="submit" class="btn btn-success rounded-pill w-100 py-2">
                            <i class="bi bi-check-lg me-1"></i>حفظ التعديلات
                        </button>
                    </form>
                </div>
            </div>
        </div>

        <!-- ══════════════════════════════════════════ -->
        <!--  Section B: Upload & Attachments Grid     -->
        <!-- ══════════════════════════════════════════ -->
        <div class="col-lg-7">

            <!-- Upload Form -->
            <div class="card border-0 shadow-sm rounded-4 mb-4">
                <div class="card-header bg-transparent border-0 pt-4 px-4 pb-0">
                    <h5 class="fw-bold mb-0"><i class="bi bi-cloud-arrow-up me-2 text-primary"></i>رفع مرفق طبي</h5>
                </div>
                <div class="card-body p-4">
                    <form asp-action="UploadAttachment" method="post" enctype="multipart/form-data">
                        @Html.AntiForgeryToken()
                        <div class="row g-3 align-items-end">
                            <div class="col-md-4">
                                <label class="form-label fw-medium">عنوان الملف</label>
                                <input type="text" name="title" class="form-control rounded-3" placeholder="مثال: تحليل دم شامل" required>
                            </div>
                            <div class="col-md-5">
                                <label class="form-label fw-medium">اختر الملف</label>
                                <input type="file" name="file" class="form-control rounded-3" accept=".jpg,.jpeg,.png,.gif,.pdf" required>
                            </div>
                            <div class="col-md-3">
                                <button type="submit" class="btn btn-primary rounded-pill w-100 py-2">
                                    <i class="bi bi-upload me-1"></i>رفع
                                </button>
                            </div>
                        </div>
                        <div class="form-text mt-2">
                            <i class="bi bi-info-circle me-1"></i>الصيغ المسموحة: JPG, PNG, GIF, PDF — الحد الأقصى: 5 ميجابايت
                        </div>
                    </form>
                </div>
            </div>

            <!-- Attachments Grid -->
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-header bg-transparent border-0 pt-4 px-4 pb-0">
                    <h5 class="fw-bold mb-0"><i class="bi bi-folder2-open me-2 text-warning"></i>المرفقات الطبية</h5>
                </div>
                <div class="card-body p-4">
                    @if (Model.Attachments.Any())
                    {
                        <div class="row g-3">
                            @foreach (var att in Model.Attachments)
                            {
                                var isPdf = att.DocumentType == "PDF";
                                <div class="col-md-6">
                                    <div class="card border rounded-3 h-100">
                                        <div class="card-body p-3 d-flex align-items-start gap-3">
                                            <div class="rounded-3 d-flex align-items-center justify-content-center @(isPdf ? "bg-danger bg-opacity-10" : "bg-info bg-opacity-10")" style="width: 48px; height: 48px; min-width: 48px;">
                                                <i class="bi @(isPdf ? "bi-file-earmark-pdf text-danger" : "bi-file-earmark-image text-info") fs-4"></i>
                                            </div>
                                            <div class="flex-grow-1 overflow-hidden">
                                                <h6 class="fw-bold mb-1 text-truncate">@att.Title</h6>
                                                <p class="text-muted small mb-2">@att.UploadedAt.ToString("dd MMM yyyy")</p>
                                                <a href="@att.FilePath" target="_blank" class="btn btn-sm btn-outline-success rounded-pill px-3">
                                                    <i class="bi bi-eye me-1"></i>عرض
                                                </a>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-4">
                            <i class="bi bi-archive text-muted mb-2" style="font-size: 2.5rem; opacity: 0.3;"></i>
                            <p class="text-muted mb-0">لا توجد مرفقات بعد. ارفع أول ملف طبي.</p>
                        </div>
                    }
                </div>
            </div>

        </div>
    </div>
</div>
