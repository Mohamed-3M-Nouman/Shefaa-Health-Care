@model ShefaaHealthCare.Models.ViewModels.BookingReceiptViewModel
@{
    ViewData["Title"] = "تم الحجز بنجاح";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-6 col-md-8">
            <div class="card border-0 shadow-sm rounded-4 text-center overflow-hidden">

                <div class="bg-success py-5">
                    <div class="rounded-circle bg-white d-inline-flex align-items-center justify-content-center mx-auto mb-3" style="width:80px;height:80px;">
                        <i class="bi bi-check-lg text-success" style="font-size:2.5rem;"></i>
                    </div>
                    <h3 class="text-white fw-bold mb-1">تم الحجز بنجاح!</h3>
                    <p class="text-white-50 mb-0">تم تأكيد موعدك وتسجيل الدفع</p>
                </div>

                <div class="card-body p-4">
                    <div class="bg-light rounded-3 p-3 mb-4">
                        <p class="text-muted small mb-1">رقم الحجز المرجعي</p>
                        <h4 class="fw-bold text-success mb-0">#SHF-@Model.AppointmentId.ToString("D6")</h4>
                    </div>

                    <div class="text-start">
                        <div class="d-flex justify-content-between align-items-center py-3 border-bottom">
                            <span class="text-muted"><i class="bi bi-person-fill me-2 text-success"></i>الطبيب</span>
                            <span class="fw-bold">@Model.DoctorName</span>
                        </div>
                        <div class="d-flex justify-content-between align-items-center py-3 border-bottom">
                            <span class="text-muted"><i class="bi bi-heart-pulse me-2 text-success"></i>التخصص</span>
                            <span class="fw-bold">@Model.SpecializationName</span>
                        </div>
                        <div class="d-flex justify-content-between align-items-center py-3 border-bottom">
                            <span class="text-muted"><i class="bi bi-calendar-event me-2 text-success"></i>التاريخ</span>
                            <span class="fw-bold">@Model.AppointmentDate.ToString("dd MMMM yyyy")</span>
                        </div>
                        <div class="d-flex justify-content-between align-items-center py-3 border-bottom">
                            <span class="text-muted"><i class="bi bi-clock me-2 text-success"></i>الوقت</span>
                            <span class="fw-bold">@Model.AppointmentDate.ToString("hh:mm tt")</span>
                        </div>
                        <div class="d-flex justify-content-between align-items-center py-3 border-bottom">
                            <span class="text-muted"><i class="bi bi-wallet2 me-2 text-success"></i>طريقة الدفع</span>
                            <span class="fw-bold">@Model.PaymentMethod</span>
                        </div>
                        <div class="d-flex justify-content-between align-items-center py-3 border-bottom">
                            <span class="text-muted"><i class="bi bi-info-circle me-2 text-success"></i>الحالة</span>
                            @if (Model.Status == "Confirmed")
                            {
                                <span class="badge bg-success rounded-pill px-3 py-2">مؤكد</span>
                            }
                            else
                            {
                                <span class="badge bg-warning text-dark rounded-pill px-3 py-2">قيد الانتظار</span>
                            }
                        </div>
                        <div class="d-flex justify-content-between align-items-center py-3">
                            <span class="text-muted"><i class="bi bi-cash me-2 text-success"></i>المبلغ</span>
                            <span class="fw-bold text-success fs-5">@Model.ConsultationFee ج.م</span>
                        </div>
                    </div>

                    <hr>

                    <div class="d-flex flex-column flex-sm-row gap-3 mt-3">
                        <a asp-controller="Patient" asp-action="Dashboard" class="btn btn-success rounded-pill flex-fill py-2">
                            <i class="bi bi-grid-1x2 me-1"></i>العودة للوحة التحكم
                        </a>
                        <a asp-controller="Patient" asp-action="Appointments" class="btn btn-outline-success rounded-pill flex-fill py-2">
                            <i class="bi bi-calendar2-check me-1"></i>عرض مواعيدي
                        </a>
                    </div>

                    <p class="text-muted small mt-4 mb-0">
                        <i class="bi bi-clock-history me-1"></i>تم الحجز في: @Model.BookedAt.ToLocalTime().ToString("dd/MM/yyyy hh:mm tt")
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>
