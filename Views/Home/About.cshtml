@{
    ViewData["Title"] = "من نحن";
}

<!-- ══════════════════════════════════════════ -->
<!--  HERO SECTION                              -->
<!-- ══════════════════════════════════════════ -->
<section class="hero-section bg-success bg-opacity-10 position-relative overflow-hidden py-5">
    <div class="container position-relative">
        <div class="row align-items-center g-5">
            <div class="col-lg-6" data-aos="fade-up">
                <span class="badge bg-success bg-opacity-25 text-success rounded-4 px-3 py-2 mb-3 fs-6">
                    <i class="bi bi-info-circle me-1"></i>من نحن
                </span>
                <h1 class="display-4 fw-800 text-dark mb-3 lh-base">
                    منصة شفاء
                    <br />
                    <span class="text-success">للرعاية الصحية الذكية</span>
                </h1>
                <p class="fs-5 text-muted mb-4 lh-lg">
                    نحن منصة طبية مبتكرة تهدف إلى تقريب المسافة بين المرضى والأطباء المتخصصين، 
                    وتوفير تجربة صحية متكاملة وآمنة وموثوقة للجميع.
                </p>
            </div>
            <div class="col-lg-6 text-center" data-aos="fade-up" data-aos-delay="200">
                <div class="bg-white rounded-5 shadow p-4">
                    <i class="bi bi-hospital" style="font-size: 8rem; color: #28a745;"></i>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ══════════════════════════════════════════ -->
<!--  ABOUT CONTENT                             -->
<!-- ══════════════════════════════════════════ -->
<section class="py-5">
    <div class="container">
        <div class="row g-5">
            <!-- Our Mission -->
            <div class="col-lg-6" data-aos="fade-up">
                <h3 class="fw-bold text-dark mb-3">
                    <i class="bi bi-target text-success me-2"></i>رسالتنا
                </h3>
                <p class="text-muted lh-lg">
                    رسالتنا هي تطوير خدمات صحية ذكية تسهل عملية الاتصال بين المرضى والأطباء 
                    المتخصصين، وتوفير ملف طبي موحد آمن يحتوي على كامل السجل الصحي للمريض، 
                    مما يساعد على تحسين جودة الرعاية الصحية وسرعة التشخيص.
                </p>
            </div>

            <!-- Our Vision -->
            <div class="col-lg-6" data-aos="fade-up" data-aos-delay="100">
                <h3 class="fw-bold text-dark mb-3">
                    <i class="bi bi-eye text-success me-2"></i>رؤيتنا
                </h3>
                <p class="text-muted lh-lg">
                    نطمح أن نكون المنصة الطبية الرائدة في منطقة الشرق الأوسط وشمال أفريقيا، 
                    حيث نستخدم أحدث تقنيات الذكاء الاصطناعي والتحليل الذكي لتقديم خدمات صحية 
                    متطورة وموثوقة تلبي احتياجات المريض بشكل كامل.
                </p>
            </div>
        </div>

        <!-- Core Values -->
        <div class="row g-4 mt-5">
            <div class="col-md-4" data-aos="fade-up">
                <div class="card border-0 shadow-sm rounded-4 h-100 p-4">
                    <div class="text-success mb-3" style="font-size: 3rem;">
                        <i class="bi bi-heart-pulse"></i>
                    </div>
                    <h5 class="fw-bold text-dark mb-3">الرعاية</h5>
                    <p class="text-muted small">
                        نضع صحة المريض في المقام الأول ونسعى دائماً لتقديم أفضل الخدمات الطبية.
                    </p>
                </div>
            </div>

            <div class="col-md-4" data-aos="fade-up" data-aos-delay="100">
                <div class="card border-0 shadow-sm rounded-4 h-100 p-4">
                    <div class="text-success mb-3" style="font-size: 3rem;">
                        <i class="bi bi-shield-lock"></i>
                    </div>
                    <h5 class="fw-bold text-dark mb-3">الأمان والخصوصية</h5>
                    <p class="text-muted small">
                        بيانات المريض محمية بأعلى معايير الأمان والتشفير العالمية.
                    </p>
                </div>
            </div>

            <div class="col-md-4" data-aos="fade-up" data-aos-delay="200">
                <div class="card border-0 shadow-sm rounded-4 h-100 p-4">
                    <div class="text-success mb-3" style="font-size: 3rem;">
                        <i class="bi bi-lightbulb"></i>
                    </div>
                    <h5 class="fw-bold text-dark mb-3">الابتكار</h5>
                    <p class="text-muted small">
                        نستخدم أحدث التقنيات والذكاء الاصطناعي لتحسين الخدمات الطبية.
                    </p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ══════════════════════════════════════════ -->
<!--  TEAM STATS                                -->
<!-- ══════════════════════════════════════════ -->
<section class="py-5 bg-success bg-opacity-10">
    <div class="container">
        <div class="row g-4 text-center">
            <div class="col-md-4" data-aos="fade-up">
                <h3 class="fw-bold text-success mb-2">+500</h3>
                <p class="text-muted">طبيب متخصص معتمد</p>
            </div>
            <div class="col-md-4" data-aos="fade-up" data-aos-delay="100">
                <h3 class="fw-bold text-success mb-2">+10,000</h3>
                <p class="text-muted">مريض مسجل وموثوق</p>
            </div>
            <div class="col-md-4" data-aos="fade-up" data-aos-delay="200">
                <h3 class="fw-bold text-success mb-2">30+</h3>
                <p class="text-muted">تخصص طبي متنوع</p>
            </div>
        </div>
    </div>
</section>
