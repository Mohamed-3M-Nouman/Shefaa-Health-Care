@{
    ViewData["Title"] = "الرئيسية";
}

<!-- ══════════════════════════════════════════ -->
<!--  HERO SECTION                              -->
<!-- ══════════════════════════════════════════ -->
<section id="heroSection" class="hero-section bg-success bg-opacity-10 position-relative overflow-hidden">
    <div class="container position-relative">
        <div class="row align-items-center g-5">
            <!-- Text Side -->
            <div class="col-lg-6" data-aos="fade-up">
                <span class="badge bg-success bg-opacity-25 text-success rounded-4 px-3 py-2 mb-3 fs-6">
                    <i class="bi bi-stars me-1"></i>منصة صحية ذكية
                </span>

                <h1 class="display-4 fw-800 text-dark mb-3 lh-base">
                    شفاء.. رفيقك الموثوق
                    <br />
                    <span class="text-success">لرعاية صحية متكاملة</span>
                </h1>

                <p class="fs-5 text-muted mb-4 lh-lg">
                    نوفر لك تجربة صحية سلسة تربطك بأفضل الأطباء المتخصصين،
                    مع ملف طبي موحد وفرز ذكي بالذكاء الاصطناعي.
                </p>

                <!-- CTA Buttons -->
                <div class="d-flex flex-wrap gap-3 mb-4" data-aos="fade-up" data-aos-delay="100">
                    @if (User.Identity != null && User.Identity.IsAuthenticated)
                    {
                        <a id="heroFindDoctor" class="btn btn-success btn-lg rounded-pill px-4 shadow-sm"
                           asp-controller="Doctor" asp-action="Index">
                            <i class="bi bi-search-heart me-2"></i>ابحث عن طبيب
                        </a>
                        <a id="heroAppointments" class="btn btn-outline-success btn-lg rounded-pill px-4"
                           href="#">
                            <i class="bi bi-calendar2-check me-2"></i>مواعيدي
                        </a>
                    }
                    else
                    {
                        <a id="heroRegister" class="btn btn-success btn-lg rounded-pill px-4 shadow-sm"
                           asp-controller="Account" asp-action="Register">
                            <i class="bi bi-person-plus me-2"></i>سجّل مجاناً
                        </a>
                        <a id="heroLearnMore" class="btn btn-outline-success btn-lg rounded-pill px-4"
                           href="#featuresSection">
                            <i class="bi bi-info-circle me-2"></i>اعرف المزيد
                        </a>
                    }
                </div>

                <!-- Stats -->
                <div class="d-flex gap-4 flex-wrap" data-aos="fade-up" data-aos-delay="200">
                    <div class="text-center">
                        <h4 class="fw-bold text-success mb-0">+500</h4>
                        <small class="text-muted">طبيب متخصص</small>
                    </div>
                    <div class="vr"></div>
                    <div class="text-center">
                        <h4 class="fw-bold text-success mb-0">+10K</h4>
                        <small class="text-muted">مريض مسجل</small>
                    </div>
                    <div class="vr"></div>
                    <div class="text-center">
                        <h4 class="fw-bold text-success mb-0">+30</h4>
                        <small class="text-muted">تخصص طبي</small>
                    </div>
                </div>
            </div>

            <!-- Illustration Side -->
            <div class="col-lg-6 text-center" data-aos="fade-up" data-aos-delay="300">
                <div class="bg-white rounded-5 shadow p-4">
                    <img src="~/images/hero-illustration.png" alt="شفاء - رعاية صحية ذكية"
                         class="img-fluid rounded-4"
                         onerror="this.parentElement.innerHTML='<div class=\'d-flex flex-column align-items-center justify-content-center py-5 text-success\'><i class=\'bi bi-heart-pulse-fill\' style=\'font-size:6rem\'></i><p class=\'mt-3 text-muted fs-5\'>شفاء للرعاية الصحية</p></div>'" />
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ══════════════════════════════════════════ -->
<!--  SEARCH BAR SECTION                        -->
<!-- ══════════════════════════════════════════ -->
<section id="searchSection" class="py-4 bg-white shadow-sm">
    <div class="container" data-aos="fade-up">
        <div class="row justify-content-center">
            <div class="col-lg-8 col-md-10">
                <form asp-controller="Doctor" asp-action="Index" method="get" class="hero-search">
                    <div class="input-group input-group-lg">
                        <button id="searchBtn" class="btn btn-success px-4 rounded-end-pill" type="submit">
                            <i class="bi bi-search me-1"></i>ابحث
                        </button>
                        <input id="searchInput" type="text" class="form-control shadow-none rounded-start-pill" name="search"
                               placeholder="ابحث عن طبيب بالاسم أو التخصص..." aria-label="بحث عن طبيب" />
                    </div>
                    <div class="d-flex flex-wrap gap-2 mt-3 justify-content-center">
                        <span class="text-muted small ms-1">بحث شائع:</span>
                        <a href="@Url.Action("Index", "Doctor", new { search = "قلب" })" class="badge bg-success bg-opacity-10 text-success text-decoration-none rounded-pill px-3 py-2">قلب</a>
                        <a href="@Url.Action("Index", "Doctor", new { search = "عظام" })" class="badge bg-success bg-opacity-10 text-success text-decoration-none rounded-pill px-3 py-2">عظام</a>
                        <a href="@Url.Action("Index", "Doctor", new { search = "جلدية" })" class="badge bg-success bg-opacity-10 text-success text-decoration-none rounded-pill px-3 py-2">جلدية</a>
                        <a href="@Url.Action("Index", "Doctor", new { search = "اسنان" })" class="badge bg-success bg-opacity-10 text-success text-decoration-none rounded-pill px-3 py-2">أسنان</a>
                        <a href="@Url.Action("Index", "Doctor", new { search = "باطنة" })" class="badge bg-success bg-opacity-10 text-success text-decoration-none rounded-pill px-3 py-2">باطنة</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</section>

<!-- ══════════════════════════════════════════ -->
<!--  FEATURES SECTION (4 Cards)                -->
<!-- ══════════════════════════════════════════ -->
<section id="featuresSection" class="py-5">
    <div class="container">
        <!-- Section Header -->
        <div class="text-center mb-5" data-aos="fade-up">
            <span class="badge bg-success bg-opacity-10 text-success rounded-4 px-3 py-2 mb-3">مميزاتنا</span>
            <h2 class="fw-bold text-dark">لماذا تختار شفاء؟</h2>
            <p class="text-muted fs-5">نقدم لك خدمات صحية مبتكرة ومتطورة</p>
        </div>

        <!-- 4 Feature Cards -->
        <div class="row g-4">
            <!-- Feature 1: AI Triage -->
            <div class="col-lg-3 col-md-6" data-aos="fade-up" data-aos-delay="100">
                <div class="card feature-card rounded-4 shadow-sm h-100 text-center p-4">
                    <div class="card-body">
                        <div class="feature-icon bg-success bg-opacity-10 text-success mb-3">
                            <i class="bi bi-robot"></i>
                        </div>
                        <h5 class="card-title fw-bold mb-3">فرز ذكي بالذكاء الاصطناعي</h5>
                        <p class="card-text text-muted">
                            يقوم نظامنا الذكي بتحليل أعراضك وتوجيهك
                            للتخصص الطبي المناسب بدقة عالية.
                        </p>
                    </div>
                </div>
            </div>

            <!-- Feature 2: Unified Medical File -->
            <div class="col-lg-3 col-md-6" data-aos="fade-up" data-aos-delay="200">
                <div class="card feature-card rounded-4 shadow-sm h-100 text-center p-4">
                    <div class="card-body">
                        <div class="feature-icon bg-success bg-opacity-10 text-success mb-3">
                            <i class="bi bi-file-earmark-medical"></i>
                        </div>
                        <h5 class="card-title fw-bold mb-3">ملف طبي موحد</h5>
                        <p class="card-text text-muted">
                            سجل طبي شامل يجمع كل تاريخك المرضي
                            والتقارير والوصفات في مكان واحد آمن.
                        </p>
                    </div>
                </div>
            </div>

            <!-- Feature 3: Appointment Booking -->
            <div class="col-lg-3 col-md-6" data-aos="fade-up" data-aos-delay="300">
                <div class="card feature-card rounded-4 shadow-sm h-100 text-center p-4">
                    <div class="card-body">
                        <div class="feature-icon bg-success bg-opacity-10 text-success mb-3">
                            <i class="bi bi-calendar-check"></i>
                        </div>
                        <h5 class="card-title fw-bold mb-3">حجز مواعيد بسهولة</h5>
                        <p class="card-text text-muted">
                            احجز موعدك مع الطبيب المناسب في ثوانٍ
                            معدودة مع إشعارات تذكيرية تلقائية.
                        </p>
                    </div>
                </div>
            </div>

            <!-- Feature 4: Security & Privacy -->
            <div class="col-lg-3 col-md-6" data-aos="fade-up" data-aos-delay="400">
                <div class="card feature-card rounded-4 shadow-sm h-100 text-center p-4">
                    <div class="card-body">
                        <div class="feature-icon bg-success bg-opacity-10 text-success mb-3">
                            <i class="bi bi-shield-lock"></i>
                        </div>
                        <h5 class="card-title fw-bold mb-3">أمان وخصوصية تامة</h5>
                        <p class="card-text text-muted">
                            بياناتك الطبية مشفرة ومحمية بأعلى معايير
                            الأمان المتوافقة مع HIPAA العالمية.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ══════════════════════════════════════════ -->
<!--  HOW IT WORKS (Only for non-logged-in)    -->
<!-- ══════════════════════════════════════════ -->
@if (User.Identity == null || !User.Identity.IsAuthenticated)
{
    <section id="howItWorks" class="py-5 bg-white">
        <div class="container">
            <div class="text-center mb-5" data-aos="fade-up">
                <span class="badge bg-success bg-opacity-10 text-success rounded-4 px-3 py-2 mb-3">كيف يعمل</span>
                <h2 class="fw-bold text-dark">٣ خطوات بسيطة</h2>
            </div>

            <div class="row g-4 text-center">
                <div class="col-md-4" data-aos="fade-up" data-aos-delay="100">
                    <div class="step-circle bg-success bg-opacity-10 rounded-circle d-inline-flex align-items-center justify-content-center mb-3">
                        <span class="fs-2 fw-bold text-success">١</span>
                    </div>
                    <h5 class="fw-bold">سجّل حسابك</h5>
                    <p class="text-muted">أنشئ حسابك كمريض أو طبيب في دقيقة واحدة</p>
                </div>
                <div class="col-md-4" data-aos="fade-up" data-aos-delay="200">
                    <div class="step-circle bg-success bg-opacity-10 rounded-circle d-inline-flex align-items-center justify-content-center mb-3">
                        <span class="fs-2 fw-bold text-success">٢</span>
                    </div>
                    <h5 class="fw-bold">اوصف حالتك</h5>
                    <p class="text-muted">أدخل أعراضك ودع الذكاء الاصطناعي يرشدك</p>
                </div>
                <div class="col-md-4" data-aos="fade-up" data-aos-delay="300">
                    <div class="step-circle bg-success bg-opacity-10 rounded-circle d-inline-flex align-items-center justify-content-center mb-3">
                        <span class="fs-2 fw-bold text-success">٣</span>
                    </div>
                    <h5 class="fw-bold">احجز موعدك</h5>
                    <p class="text-muted">اختر الطبيب والموعد المناسب واحصل على رعايتك</p>
                </div>
            </div>
        </div>
    </section>
}

<!-- ══════════════════════════════════════════ -->
<!--  DOCTOR CTA SECTION (Only for non-logged-in) -->
<!-- ══════════════════════════════════════════ -->
@if (User.Identity == null || !User.Identity.IsAuthenticated)
{
    <section id="doctorCta" class="py-5">
        <div class="container" data-aos="fade-up">
            <div class="doctor-cta text-white rounded-5 p-5">
                <div class="row align-items-center">
                    <div class="col-lg-8 mb-3 mb-lg-0">
                        <h2 class="fw-bold mb-3">
                            <i class="bi bi-heart-pulse me-2"></i>انضم لشبكة أطباء شفاء
                        </h2>
                        <p class="fs-5 mb-0 opacity-75">
                            وسّع قاعدة مرضاك وأدِر عيادتك بذكاء. انضم لمئات الأطباء
                            الذين يثقون بمنصة شفاء.
                        </p>
                    </div>
                    <div class="col-lg-4 text-lg-end">
                        <a id="ctaRegisterDoctor" class="btn btn-light text-success btn-lg rounded-4 px-4 fw-bold shadow-sm"
                           asp-controller="Account" asp-action="Register">
                            <i class="bi bi-person-plus me-1"></i>سجل كطبيب الآن
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </section>
}
