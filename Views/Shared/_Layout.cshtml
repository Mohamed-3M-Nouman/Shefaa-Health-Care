@using Microsoft.AspNetCore.Identity
@inject SignInManager<ShefaaHealthCare.Models.ApplicationUser> SignInManager
@inject UserManager<ShefaaHealthCare.Models.ApplicationUser> UserManager

<!DOCTYPE html>
<html dir="rtl" lang="ar">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - شفاء للرعاية الصحية</title>
    <meta name="description" content="شفاء - منصة متكاملة للرعاية الصحية الذكية. نربط بين المرضى والأطباء لتوفير تجربة صحية سلسة وآمنة." />
    <meta name="author" content="Shefaa HealthCare" />
    <meta name="theme-color" content="#198754" />

    <!-- Open Graph -->
    <meta property="og:title" content="@ViewData["Title"] - شفاء للرعاية الصحية" />
    <meta property="og:description" content="منصة متكاملة للرعاية الصحية الذكية" />
    <meta property="og:type" content="website" />

    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@300;400;500;700;800&display=swap" rel="stylesheet" />

    <!-- Bootstrap 5 RTL -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.rtl.min.css" rel="stylesheet"
          integrity="sha384-dpuaG1suU0eT09tx5plTaGMLBsfDLzUCCUXOY2j/LSvXYuG6Bqs43ALlhIqAJVRb" crossorigin="anonymous" />

    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />

    <!-- AOS (Animate On Scroll) -->
    <link href="https://cdn.jsdelivr.net/npm/aos@2.3.4/dist/aos.css" rel="stylesheet" />

    <!-- Site CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <!-- Favicon -->
    <link rel="icon" type="image/x-icon" href="~/favicon.ico" />

    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="d-flex flex-column min-vh-100">

    <!-- ══════════════════════════════════════════ -->
    <!--  NAVBAR                                    -->
    <!-- ══════════════════════════════════════════ -->
    <nav id="mainNav" class="navbar navbar-expand-lg bg-white shadow-sm sticky-top py-2">
        <div class="container">

            <!-- Logo / Brand -->
            <a id="navBrand" class="navbar-brand d-flex align-items-center gap-2 py-1" asp-controller="Home" asp-action="Index">
                <span class="d-inline-flex align-items-center justify-content-center rounded-3 bg-success bg-opacity-10"
                      style="width:38px;height:38px;">
                    <i class="bi bi-heart-pulse-fill text-success fs-5"></i>
                </span>
                <span class="fw-bold fs-5 text-success">Shefaa</span>
            </a>

            <!-- Toggler -->
            <button id="navToggler" class="navbar-toggler border-0 shadow-none" type="button"
                    data-bs-toggle="collapse" data-bs-target="#mainNavbar"
                    aria-controls="mainNavbar" aria-expanded="false" aria-label="القائمة">
                <span class="navbar-toggler-icon"></span>
            </button>

            <!-- Collapsible Content -->
            <div class="collapse navbar-collapse" id="mainNavbar">

                <!-- ─── Nav Links (Auth-Aware) ─── -->
                <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                    @if (User.Identity != null && User.Identity.IsAuthenticated)
                    {
                        <!-- Authenticated Navigation -->
                        <li class="nav-item">
                            <a id="navDashboard" class="nav-link text-dark fw-medium" asp-controller="Patient" asp-action="Dashboard">
                                <i class="bi bi-grid-1x2 me-1"></i>لوحة التحكم
                            </a>
                        </li>
                        <li class="nav-item">
                            <a id="navDoctors" class="nav-link text-dark fw-medium" asp-controller="Doctor" asp-action="Index">
                                <i class="bi bi-search-heart me-1"></i>ابحث عن طبيب
                            </a>
                        </li>
                        <li class="nav-item">
                            <a id="navAiTriage" class="nav-link text-dark fw-bold text-success" asp-controller="Ai" asp-action="Triage">
                                <i class="bi bi-robot me-1"></i>الممرض الذكي
                            </a>
                        </li>
                        <li class="nav-item">
                            <a id="navAppointments" class="nav-link text-dark fw-medium" asp-controller="Patient" asp-action="Appointments">
                                <i class="bi bi-calendar2-check me-1"></i>المواعيد
                            </a>
                        </li>
                        <li class="nav-item">
                            <a id="navMedicalRecords" class="nav-link text-dark fw-medium" asp-controller="Patient" asp-action="MedicalProfile">
                                <i class="bi bi-folder2-open me-1"></i>السجلات الطبية
                            </a>
                        </li>
                        <li class="nav-item dropdown">
                            <a id="navSettingsDropdown" class="nav-link dropdown-toggle text-dark fw-medium" href="#"
                               role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="bi bi-gear me-1"></i>الإعدادات
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end border-0 shadow-sm rounded-3">
                                <li>
                                    <a id="navProfileSettings" class="dropdown-item py-2" asp-controller="Account" asp-action="Index">
                                        <i class="bi bi-person-circle me-2 text-success"></i>الملف الشخصي
                                    </a>
                                </li>
                                <li><hr class="dropdown-divider" /></li>
                                <li>
                                    <a id="navSecuritySettings" class="dropdown-item py-2" href="#">
                                        <i class="bi bi-shield-lock me-2 text-success"></i>الأمان والخصوصية
                                    </a>
                                </li>
                                <li>
                                    <a id="navNotificationSettings" class="dropdown-item py-2" href="#">
                                        <i class="bi bi-bell me-2 text-success"></i>الإشعارات
                                    </a>
                                </li>
                            </ul>
                        </li>
                    }
                    else
                    {
                        <!-- Public Navigation -->
                        <li class="nav-item">
                            <a id="navHome" class="nav-link text-dark fw-medium" asp-controller="Home" asp-action="Index">
                                <i class="bi bi-house-heart me-1"></i>الرئيسية
                            </a>
                        </li>
                        <li class="nav-item">
                            <a id="navAbout" class="nav-link text-dark fw-medium" asp-controller="Home" asp-action="About">
                                <i class="bi bi-info-circle me-1"></i>من نحن
                            </a>
                        </li>
                        <li class="nav-item">
                            <a id="navServices" class="nav-link text-dark fw-medium" asp-controller="Home" asp-action="Services">
                                <i class="bi bi-hospital me-1"></i>خدماتنا
                            </a>
                        </li>
                        <li class="nav-item">
                            <a id="navAiTriagePub" class="nav-link text-dark fw-bold text-success" asp-controller="Ai" asp-action="Triage">
                                <i class="bi bi-robot me-1"></i>الممرض الذكي
                            </a>
                        </li>
                        <li class="nav-item">
                            <a id="navContact" class="nav-link text-dark fw-medium" asp-controller="Home" asp-action="Contact">
                                <i class="bi bi-envelope me-1"></i>تواصل معنا
                            </a>
                        </li>
                    }
                </ul>

                <!-- ─── Auth Buttons ─── -->
                <div class="d-flex flex-column flex-lg-row align-items-stretch align-items-lg-center gap-2 mt-3 mt-lg-0">
                    @if (User.Identity != null && User.Identity.IsAuthenticated)
                    {
                        <a id="btnUserProfile" class="btn btn-outline-success rounded-pill px-3 d-flex align-items-center justify-content-center gap-1"
                           asp-controller="Account" asp-action="Index">
                            <i class="bi bi-person-circle"></i>
                            <span>الملف الشخصي</span>
                        </a>
                        <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <button id="btnLogout" type="submit"
                                    class="btn btn-success rounded-pill px-3 w-100 d-flex align-items-center justify-content-center gap-1">
                                <i class="bi bi-box-arrow-right"></i>
                                <span>تسجيل الخروج</span>
                            </button>
                        </form>
                    }
                    else
                    {
                        <a id="btnLogin" class="btn btn-outline-success rounded-pill px-3 d-flex align-items-center justify-content-center gap-1"
                           asp-controller="Account" asp-action="Login">
                            <i class="bi bi-box-arrow-in-left"></i>
                            <span>تسجيل الدخول</span>
                        </a>
                        <a id="btnRegister" class="btn btn-success rounded-pill px-3 d-flex align-items-center justify-content-center gap-1"
                           asp-controller="Account" asp-action="Register">
                            <i class="bi bi-person-plus"></i>
                            <span>إنشاء حساب</span>
                        </a>
                    }
                </div>

            </div>
        </div>
    </nav>

    <!-- ══════════════════════════════════════════ -->
    <!--  MAIN CONTENT                              -->
    <!-- ══════════════════════════════════════════ -->
    <main role="main" class="flex-grow-1">
        @RenderBody()
    </main>

    <!-- ══════════════════════════════════════════ -->
    <!--  FOOTER                                    -->
    <!-- ══════════════════════════════════════════ -->
    <footer id="siteFooter" class="site-footer text-white pt-5 pb-3 mt-auto">
        <div class="container">
            <div class="row g-4 mb-4">

                <!-- ─── Brand Column ─── -->
                <div class="col-lg-4 col-md-6 mb-3">
                    <div class="d-flex align-items-center gap-2 mb-3">
                        <span class="d-inline-flex align-items-center justify-content-center rounded-3 bg-success bg-opacity-25"
                              style="width:40px;height:40px;">
                            <i class="bi bi-heart-pulse-fill text-success fs-5"></i>
                        </span>
                        <h5 class="fw-bold mb-0">Shefaa</h5>
                    </div>
                    <p class="text-white-50 small lh-lg mb-3">
                        منصة متكاملة للرعاية الصحية الذكية. نربط بين المرضى والأطباء
                        لتوفير تجربة صحية سلسة وآمنة تعتمد على أحدث التقنيات.
                    </p>
                    <!-- Social Media -->
                    <div id="footer-social" class="d-flex gap-2">
                        <a href="https://www.facebook.com" class="btn btn-outline-light btn-sm rounded-circle d-inline-flex align-items-center justify-content-center"
                           style="width:36px;height:36px;" aria-label="Facebook">
                            <i class="bi bi-facebook"></i>
                        </a>
                        <a href="https://x.com" class="btn btn-outline-light btn-sm rounded-circle d-inline-flex align-items-center justify-content-center"
                           style="width:36px;height:36px;" aria-label="X (Twitter)">
                            <i class="bi bi-twitter-x"></i>
                        </a>
                        <a href="https://www.instagram.com" class="btn btn-outline-light btn-sm rounded-circle d-inline-flex align-items-center justify-content-center"
                           style="width:36px;height:36px;" aria-label="Instagram">
                            <i class="bi bi-instagram"></i>
                        </a>
                        <a href="https://www.linkedin.com" class="btn btn-outline-light btn-sm rounded-circle d-inline-flex align-items-center justify-content-center"
                           style="width:36px;height:36px;" aria-label="LinkedIn">
                            <i class="bi bi-linkedin"></i>
                        </a>
                        <a href="https://www.youtube.com" class="btn btn-outline-light btn-sm rounded-circle d-inline-flex align-items-center justify-content-center"
                           style="width:36px;height:36px;" aria-label="YouTube">
                            <i class="bi bi-youtube"></i>
                        </a>
                    </div>
                </div>

                <!-- ─── About Column ─── -->
                <div class="col-lg-2 col-md-3 col-6 mb-3">
                    <h6 class="fw-bold mb-3 text-white">عن شفاء</h6>
                    <ul class="list-unstyled small">
                        <li class="mb-2">
                            <a class="text-white-50 text-decoration-none" asp-controller="Home" asp-action="About">
                                <i class="bi bi-chevron-left me-1 small"></i>من نحن
                            </a>
                        </li>
                        <li class="mb-2">
                            <a class="text-white-50 text-decoration-none" asp-controller="Home" asp-action="Services">
                                <i class="bi bi-chevron-left me-1 small"></i>خدماتنا
                            </a>
                        </li>
                        <li class="mb-2">
                            <a class="text-white-50 text-decoration-none" asp-controller="Account" asp-action="Register">
                                <i class="bi bi-chevron-left me-1 small"></i>انضم إلينا
                            </a>
                        </li>
                    </ul>
                </div>

                <!-- ─── Support Column ─── -->
                <div class="col-lg-2 col-md-3 col-6 mb-3">
                    <h6 class="fw-bold mb-3 text-white">الدعم</h6>
                    <ul class="list-unstyled small">
                        <li class="mb-2">
                            <a class="text-white-50 text-decoration-none" asp-controller="Home" asp-action="PopularQuestions">
                                <i class="bi bi-chevron-left me-1 small"></i>الأسئلة الشائعة
                            </a>
                        </li>
                        <li class="mb-2">
                            <a class="text-white-50 text-decoration-none" asp-controller="Home" asp-action="Contact">
                                <i class="bi bi-chevron-left me-1 small"></i>الإبلاغ عن مشكلة
                            </a>
                        </li>
                    </ul>
                </div>

                <!-- ─── Legal Column ─── -->
                <div class="col-lg-2 col-md-3 col-6 mb-3">
                    <h6 class="fw-bold mb-3 text-white">قانوني</h6>
                    <ul class="list-unstyled small">
                        <li class="mb-2">
                            <a class="text-white-50 text-decoration-none" asp-controller="Home" asp-action="Privacy">
                                <i class="bi bi-chevron-left me-1 small"></i>سياسة الخصوصية
                            </a>
                        </li>
                        <li class="mb-2">
                            <a class="text-white-50 text-decoration-none" asp-controller="Home" asp-action="Terms">
                                <i class="bi bi-chevron-left me-1 small"></i>الشروط والأحكام
                            </a>
                        </li>
                        <li class="mb-2">
                            <a class="text-white-50 text-decoration-none" asp-controller="Home" asp-action="Hipaa">
                                <i class="bi bi-shield-check me-1 small"></i>الامتثال لـ HIPAA
                            </a>
                        </li>
                        <li class="mb-2">
                            <a class="text-white-50 text-decoration-none" asp-controller="Home" asp-action="Cookies">
                                <i class="bi bi-chevron-left me-1 small"></i>سياسة الكوكيز
                            </a>
                        </li>
                    </ul>
                </div>

                <!-- ─── Contact Column ─── -->
                <div id="footer-contact" class="col-lg-2 col-md-3 col-6 mb-3">
                    <h6 class="fw-bold mb-3 text-white">تواصل معنا</h6>
                    <ul class="list-unstyled small">
                        <li class="mb-2">
                            <a class="text-white-50 text-decoration-none" asp-controller="Home" asp-action="Contact">
                                <i class="bi bi-chevron-left me-1 small"></i>اتصل بنا
                            </a>
                        </li>
                        <li class="mb-2 text-white-50">
                            <i class="bi bi-envelope-at me-2 text-success"></i>info&#64;shefaa.com
                        </li>
                        <li class="mb-2 text-white-50">
                            <i class="bi bi-telephone me-2 text-success"></i>+20 123 456 7890
                        </li>
                        <li class="mb-2 text-white-50">
                            <i class="bi bi-geo-alt me-2 text-success"></i>القاهرة، مصر
                        </li>
                        <li class="mb-2 text-white-50">
                            <i class="bi bi-clock me-2 text-success"></i>24/7 دعم فني
                        </li>
                    </ul>
                </div>
            </div>

            <!-- ─── Divider ─── -->
            <hr class="border-secondary opacity-25 my-3" />

            <!-- ─── Bottom Bar ─── -->
            <div class="row align-items-center">
                <div class="col-md-6 text-center text-md-start">
                    <p class="text-white-50 small mb-0">
                        &copy; @DateTime.Now.Year Shefaa HealthCare. جميع الحقوق محفوظة.
                    </p>
                </div>
                <div class="col-md-6 text-center text-md-end mt-2 mt-md-0">
                    <span class="badge bg-success bg-opacity-25 text-success-emphasis rounded-pill px-3 py-2 small">
                        <i class="bi bi-shield-fill-check me-1" color="white"></i>بيانات مشفرة ومحمية
                    </span>
                </div>
            </div>
        </div>
    </footer>

    <!-- ══════════════════════════════════════════ -->
    <!--  SCRIPTS                                   -->
    <!-- ══════════════════════════════════════════ -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
            integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
    <script src="https://cdn.jsdelivr.net/npm/aos@2.3.4/dist/aos.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        AOS.init({
            duration: 700,
            easing: 'ease-out-cubic',
            once: true
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
