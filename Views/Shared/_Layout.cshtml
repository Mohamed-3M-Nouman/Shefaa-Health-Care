<!DOCTYPE html>
<html dir="rtl" lang="ar">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - شفاء للرعاية الصحية</title>
    <meta name="description" content="شفاء - منصة متكاملة للرعاية الصحية الذكية" />

    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@300;400;500;700;800&display=swap" rel="stylesheet" />

    <!-- Bootstrap 5 RTL -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.rtl.min.css" rel="stylesheet" />

    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />

    <!-- AOS (Animate On Scroll) -->
    <link href="https://cdn.jsdelivr.net/npm/aos@2.3.4/dist/aos.css" rel="stylesheet" />

    <!-- Site CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

    <!-- ══════════════════════════════════════════ -->
    <!--  NAVBAR                                    -->
    <!-- ══════════════════════════════════════════ -->
    <nav class="navbar navbar-expand-lg bg-white shadow-sm sticky-top py-2">
        <div class="container">
            <!-- Logo / Brand -->
            <a class="navbar-brand d-flex align-items-center gap-2" asp-controller="Home" asp-action="Index">
                <img src="~/images/logo.png" alt="شفاء" onerror="this.style.display='none'" />
                <span class="fw-bold fs-5 text-success">شفاء</span>
            </a>

            <!-- Toggler -->
            <button class="navbar-toggler border-0" type="button"
                    data-bs-toggle="collapse" data-bs-target="#mainNavbar"
                    aria-controls="mainNavbar" aria-expanded="false" aria-label="القائمة">
                <span class="navbar-toggler-icon"></span>
            </button>

            <!-- Nav Links -->
            <div class="collapse navbar-collapse" id="mainNavbar">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                    <li class="nav-item">
                        <a class="nav-link text-dark" asp-controller="Home" asp-action="Index">
                            <i class="bi bi-house-heart me-1"></i>الرئيسية
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-dark" asp-controller="Home" asp-action="Privacy">
                            <i class="bi bi-info-circle me-1"></i>من نحن
                        </a>
                    </li>
                </ul>

                <!-- Auth Buttons -->
                <div class="d-flex gap-2 mt-2 mt-lg-0">
                    @if (User.Identity != null && User.Identity.IsAuthenticated)
                    {
                        <a class="btn btn-outline-success rounded-4 px-3" asp-controller="Home" asp-action="Index">
                            <i class="bi bi-grid me-1"></i>لوحة التحكم
                        </a>
                        <a class="btn btn-outline-success rounded-4 px-3" asp-controller="Account" asp-action="Index">
                            <i class="bi bi-person-circle me-1"></i>الحساب
                        </a>
                        <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-success rounded-4 px-3">
                                <i class="bi bi-box-arrow-right me-1"></i>تسجيل الخروج
                            </button>
                        </form>
                    }
                    else
                    {
                        <a class="btn btn-outline-success rounded-4 px-3" asp-controller="Account" asp-action="Login">
                            <i class="bi bi-box-arrow-in-left me-1"></i>تسجيل الدخول
                        </a>
                        <a class="btn btn-success rounded-4 px-3" asp-controller="Account" asp-action="Register">
                            <i class="bi bi-person-plus me-1"></i>إنشاء حساب
                        </a>
                    }
                </div>
            </div>
        </div>
    </nav>

    <!-- ══════════════════════════════════════════ -->
    <!--  MAIN CONTENT                              -->
    <!-- ══════════════════════════════════════════ -->
    <main role="main">
        @RenderBody()
    </main>

    <!-- ══════════════════════════════════════════ -->
    <!--  FOOTER                                    -->
    <!-- ══════════════════════════════════════════ -->
    <footer class="site-footer text-white pt-5 pb-4 mt-5">
        <div class="container">
            <div class="row g-4">
                <!-- Brand -->
                <div class="col-lg-4 mb-3">
                    <h5 class="fw-bold mb-3">
                        <i class="bi bi-heart-pulse-fill text-success me-2"></i>شفاء
                    </h5>
                    <p class="text-white-50 small">
                        منصة متكاملة للرعاية الصحية الذكية. نربط بين المرضى والأطباء
                        لتوفير تجربة صحية سلسة وآمنة.
                    </p>
                </div>

                <!-- Quick Links -->
                <div class="col-lg-2 col-md-4 mb-3">
                    <h6 class="fw-bold mb-3">روابط سريعة</h6>
                    <ul class="list-unstyled small">
                        <li class="mb-2">
                            <a class="text-white-50 text-decoration-none" asp-controller="Home" asp-action="Index">الرئيسية</a>
                        </li>
                        <li class="mb-2">
                            <a class="text-white-50 text-decoration-none" asp-controller="Home" asp-action="Privacy">من نحن</a>
                        </li>
                        <li class="mb-2">
                            <a class="text-white-50 text-decoration-none" asp-controller="Account" asp-action="Register">انضم كطبيب</a>
                        </li>
                    </ul>
                </div>

                <!-- Support -->
                <div class="col-lg-3 col-md-4 mb-3">
                    <h6 class="fw-bold mb-3">الدعم</h6>
                    <ul class="list-unstyled small">
                        <li class="mb-2">
                            <a class="text-white-50 text-decoration-none" href="#">الأسئلة الشائعة</a>
                        </li>
                        <li class="mb-2">
                            <a class="text-white-50 text-decoration-none" href="#">سياسة الخصوصية</a>
                        </li>
                        <li class="mb-2">
                            <a class="text-white-50 text-decoration-none" href="#">الشروط والأحكام</a>
                        </li>
                    </ul>
                </div>

                <!-- Contact -->
                <div class="col-lg-3 col-md-4 mb-3">
                    <h6 class="fw-bold mb-3">تواصل معنا</h6>
                    <ul class="list-unstyled small">
                        <li class="mb-2 text-white-50">
                            <i class="bi bi-envelope me-2"></i>info&#64;shefaa.com
                        </li>
                        <li class="mb-2 text-white-50">
                            <i class="bi bi-telephone me-2"></i>+20 123 456 7890
                        </li>
                    </ul>
                    <div class="d-flex gap-3 mt-3">
                        <a href="#" class="text-white-50 fs-5"><i class="bi bi-facebook"></i></a>
                        <a href="#" class="text-white-50 fs-5"><i class="bi bi-twitter-x"></i></a>
                        <a href="#" class="text-white-50 fs-5"><i class="bi bi-instagram"></i></a>
                    </div>
                </div>
            </div>

            <hr class="border-secondary my-4" />

            <div class="text-center text-white-50 small">
                <p class="mb-0">
                    &copy; @DateTime.Now.Year شفاء للرعاية الصحية. جميع الحقوق محفوظة.
                    <i class="bi bi-shield-check text-success me-1"></i>
                </p>
            </div>
        </div>
    </footer>

    <!-- Scripts -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/aos@2.3.4/dist/aos.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        AOS.init({
            duration: 700,
            easing: 'ease-out-cubic',
            once: true
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
