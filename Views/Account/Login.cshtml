@model ShefaaHealthCare.Models.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "تسجيل الدخول";
    Layout = null;
}

<!DOCTYPE html>
<html dir="rtl" lang="ar">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>شفاء - تسجيل الدخول</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.rtl.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;500;700;800&display=swap" rel="stylesheet" />
    <link href="~/css/account.css" rel="stylesheet" />
</head>
<body class="account-bg d-flex align-items-center">

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-10 col-lg-8 col-xl-7">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <div class="row g-0">
                    
                    <!-- Form Section -->
                    <div class="col-md-7 p-4 p-md-5">
                        <div class="text-center mb-4">
                            <img src="~/images/logo.png" alt="Shefaa" class="auth-logo mb-3" onerror="this.classList.add('d-none')" />
                            <h4 class="fw-bold text-success">مرحباً بك مجدداً</h4>
                            <p class="text-muted small">قم بتسجيل الدخول للوصول إلى حسابك</p>
                        </div>

                        @if (TempData["SuccessMessage"] != null)
                        {
                            <div class="alert alert-success rounded-3 small py-2 text-center">
                                <i class="bi bi-check-circle-fill me-1"></i> @TempData["SuccessMessage"]
                            </div>
                        }

                        <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-3 small py-2"></div>

                        <form asp-action="Login" asp-controller="Account" method="post">
                            
                            
                            <!-- Email -->
                            <div class="form-floating mb-3">
                                <input asp-for="Email" class="form-control rounded-3 text-start" placeholder="name@example.com" dir="ltr" />
                                <label asp-for="Email"><i class="bi bi-envelope me-1"></i> البريد الإلكتروني</label>
                                <span asp-validation-for="Email" class="text-danger small"></span>
                            </div>

                            <!-- Password -->
                            <div class="form-floating mb-3">
                                <input asp-for="Password" type="password" class="form-control rounded-3 text-start" placeholder="Password" dir="ltr" />
                                <label asp-for="Password"><i class="bi bi-lock me-1"></i> كلمة المرور</label>
                                <span asp-validation-for="Password" class="text-danger small"></span>
                            </div>

                            <!-- Options -->
                            <div class="d-flex justify-content-between align-items-center mb-4 small">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" asp-for="RememberMe" id="rememberMe">
                                    <label class="form-check-label text-muted" for="rememberMe">
                                        تذكرني
                                    </label>
                                </div>
                                <a asp-action="ForgotPassword" class="text-success text-decoration-none fw-medium">نسيت كلمة المرور؟</a>
                            </div>

                            <button type="submit" class="btn btn-success w-100 rounded-pill py-2 fw-bold mb-3">
                                تسجيل الدخول <i class="bi bi-box-arrow-in-left ms-1"></i>
                            </button>
                        </form>

                        <div class="text-center mt-4 pt-3 border-top">
                            <span class="text-muted small">ليس لديك حساب؟</span>
                            <a asp-action="Register" class="text-success fw-bold text-decoration-none ms-1">إنشاء حساب جديد</a>
                        </div>
                    </div>

                    <!-- Side Image / Info Section -->
                    <div class="col-md-5 d-none d-md-block" style="background: linear-gradient(135deg, var(--sg), var(--sg-d));">
                        <div class="h-100 d-flex flex-column justify-content-center align-items-center text-white p-4 text-center">
                            <i class="bi bi-heart-pulse text-white opacity-50 display-1 mb-4"></i>
                            <h3 class="fw-bold mb-3">رعايتك الصحية، أولوية</h3>
                            <p class="text-white-50 small mb-0">احجز مواعيدك، تابع سجلاتك الطبية، وتواصل مع أفضل الأطباء بسهولة وأمان.</p>
                        </div>
                    </div>

                </div>
            </div>
            
            <div class="text-center mt-4">
                <a asp-controller="Home" asp-action="Index" class="text-muted text-decoration-none small">
                    <i class="bi bi-arrow-right me-1"></i> العودة للرئيسية
                </a>
            </div>
        </div>
    </div>
</div>

<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<partial name="_ValidationScriptsPartial" />

</body>
</html>
