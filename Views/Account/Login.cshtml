@model ShefaaHealthCare.Models.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "تسجيل الدخول";
    Layout = null;
}

<!DOCTYPE html>
<html dir="rtl" lang="ar">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>شفاء - تسجيل الدخول</title>
    <meta name="description" content="سجّل دخولك إلى منصة شفاء للرعاية الصحية" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.rtl.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@300;400;500;700;800&display=swap" rel="stylesheet" />
    <style>
        :root {
            --shefaa-green: #198754;
            --shefaa-green-light: #d1e7dd;
            --shefaa-green-dark: #146c43;
            --shefaa-bg: #f0f6f3;
        }
        * { font-family: 'Tajawal', sans-serif; }
        body {
            background: var(--shefaa-bg);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .login-card {
            max-width: 460px;
            width: 100%;
            border: none;
            border-radius: 1.5rem;
            box-shadow: 0 8px 40px rgba(25, 135, 84, 0.10), 0 1.5px 6px rgba(0,0,0,0.04);
            overflow: hidden;
        }
        .login-header {
            background: linear-gradient(135deg, var(--shefaa-green), var(--shefaa-green-dark));
            padding: 2.5rem 2rem 2rem;
            text-align: center;
        }
        .login-header img { height: 60px; margin-bottom: 0.75rem; }
        .login-header h1 { font-size: 1.5rem; font-weight: 700; color: #fff; margin: 0; }
        .login-header p { color: rgba(255,255,255,0.8); font-size: 0.95rem; margin: 0.25rem 0 0; }
        .login-body { padding: 2rem 2rem 1.5rem; }
        .form-floating > .form-control {
            border-radius: 1rem;
            border: 1.5px solid #dee2e6;
            transition: border-color 0.2s, box-shadow 0.2s;
        }
        .form-floating > .form-control:focus {
            border-color: var(--shefaa-green);
            box-shadow: 0 0 0 0.2rem rgba(25,135,84,0.15);
        }
        .btn-shefaa {
            background: linear-gradient(135deg, var(--shefaa-green), var(--shefaa-green-dark));
            border: none; color: #fff; border-radius: 1rem;
            padding: 0.75rem; font-size: 1.1rem; font-weight: 600;
            transition: transform 0.15s, box-shadow 0.15s;
        }
        .btn-shefaa:hover {
            transform: translateY(-1px);
            box-shadow: 0 4px 15px rgba(25,135,84,0.3);
            color: #fff;
        }
        .toggle-password {
            position: absolute; left: 12px; top: 50%; transform: translateY(-50%);
            background: none; border: none; color: #6c757d; z-index: 5; cursor: pointer;
        }
        .divider { display: flex; align-items: center; margin: 1.25rem 0; color: #adb5bd; font-size: 0.85rem; }
        .divider::before, .divider::after { content: ''; flex: 1; border-top: 1px solid #dee2e6; }
        .divider::before { margin-left: 0.75rem; }
        .divider::after { margin-right: 0.75rem; }
        .pulse-dot {
            width: 8px; height: 8px; background: #4ade80; border-radius: 50%;
            display: inline-block; margin-left: 6px;
            animation: pulse 2s infinite;
        }
        @@keyframes pulse {
            0%, 100% { opacity: 1; transform: scale(1); }
            50% { opacity: .5; transform: scale(1.3); }
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-12">
                <div class="card login-card mx-auto">

                    <!-- Header -->
                    <div class="login-header">
                        <img src="~/images/logo.png" alt="شفاء" onerror="this.style.display='none'" />
                        <h1><i class="bi bi-heart-pulse-fill me-2"></i>شفاء</h1>
                        <p>منصة الرعاية الصحية <span class="pulse-dot"></span></p>
                    </div>

                    <!-- Body -->
                    <div class="login-body bg-white">
                        <h2 class="h5 fw-bold text-center mb-4" style="color: var(--shefaa-green);">
                            تسجيل الدخول إلى حسابك
                        </h2>

                        <!-- Validation Summary -->
                        <div asp-validation-summary="All" class="alert alert-danger rounded-4 small py-2" role="alert"></div>

                        <form asp-action="Login" asp-controller="Account" method="post" id="loginForm">
                            <input type="hidden" asp-for="@Model.RememberMe" />

                            <!-- Email -->
                            <div class="form-floating mb-3">
                                <input asp-for="Email" type="email" class="form-control" id="loginEmail"
                                       placeholder="البريد الإلكتروني" autocomplete="email" />
                                <label for="loginEmail"><i class="bi bi-envelope me-1"></i>البريد الإلكتروني</label>
                                <span asp-validation-for="Email" class="text-danger small"></span>
                            </div>

                            <!-- Password -->
                            <div class="form-floating mb-3 position-relative">
                                <input asp-for="Password" type="password" class="form-control" id="loginPassword"
                                       placeholder="كلمة المرور" autocomplete="current-password" />
                                <label for="loginPassword"><i class="bi bi-lock me-1"></i>كلمة المرور</label>
                                <button type="button" class="toggle-password" onclick="togglePass('loginPassword', this)">
                                    <i class="bi bi-eye"></i>
                                </button>
                                <span asp-validation-for="Password" class="text-danger small"></span>
                            </div>

                            <!-- Remember Me -->
                            <div class="form-check mb-4">
                                <input asp-for="RememberMe" class="form-check-input rounded-3" type="checkbox" id="rememberMe" />
                                <label class="form-check-label text-muted" for="rememberMe">تذكرني</label>
                            </div>

                            <!-- Submit -->
                            <button type="submit" class="btn btn-shefaa w-100 mb-3" id="loginSubmitBtn">
                                <i class="bi bi-box-arrow-in-left me-1"></i>
                                تسجيل الدخول
                            </button>
                        </form>

                        <div class="divider">أو</div>

                        <!-- Register Link -->
                        <div class="text-center">
                            <span class="text-muted">ليس لديك حساب؟</span>
                            <a asp-action="Register" asp-controller="Account" class="fw-bold text-decoration-none"
                               style="color: var(--shefaa-green);">
                                إنشاء حساب جديد <i class="bi bi-arrow-left"></i>
                            </a>
                        </div>
                    </div>

                    <!-- Footer -->
                    <div class="card-footer bg-light text-center border-0 py-3">
                        <small class="text-muted">
                            <i class="bi bi-shield-check me-1 text-success"></i>
                            جميع بياناتك محمية ومشفرة بالكامل
                        </small>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function togglePass(inputId, btn) {
            const input = document.getElementById(inputId);
            const icon = btn.querySelector('i');
            if (input.type === 'password') {
                input.type = 'text';
                icon.classList.replace('bi-eye', 'bi-eye-slash');
            } else {
                input.type = 'password';
                icon.classList.replace('bi-eye-slash', 'bi-eye');
            }
        }

        // Remove empty validation summary
        document.addEventListener('DOMContentLoaded', () => {
            const vs = document.querySelector('[data-valmsg-summary]') || document.querySelector('.validation-summary-valid');
            if (vs && vs.classList.contains('validation-summary-valid')) {
                vs.style.display = 'none';
            }
            const alerts = document.querySelectorAll('.alert');
            alerts.forEach(a => {
                if (a.textContent.trim() === '') a.style.display = 'none';
            });
        });
    </script>
</body>
</html>
