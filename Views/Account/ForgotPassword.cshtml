@model ShefaaHealthCare.Models.ViewModels.ForgotPasswordViewModel
@{
    ViewData["Title"] = "نسيت كلمة المرور";
    Layout = null;
}

<!DOCTYPE html>
<html dir="rtl" lang="ar">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>شفاء - استعادة كلمة المرور</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.rtl.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;500;700;800&display=swap" rel="stylesheet" />
    <link href="~/css/account.css" rel="stylesheet" />
</head>
<body class="account-bg d-flex align-items-center">

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6 col-xl-5">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <div class="p-4 p-md-5">
                    
                    <div class="text-center mb-4">
                        <div class="bg-success bg-opacity-10 rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 80px; height: 80px;">
                            <i class="bi bi-shield-lock text-success display-5"></i>
                        </div>
                        <h4 class="fw-bold text-success">استعادة كلمة المرور</h4>
                        <p class="text-muted small">يرجى إدخال البريد الإلكتروني ورقم الهاتف المرتبطين بحسابك للتحقق من هويتك.</p>
                    </div>

                    <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-3 small py-2"></div>

                    <form asp-action="ForgotPassword" method="post">
                        
                        <!-- Email -->
                        <div class="form-floating mb-3">
                            <input asp-for="Email" type="email" class="form-control rounded-3 text-start" placeholder="name@example.com" dir="ltr" />
                            <label asp-for="Email"><i class="bi bi-envelope me-1"></i> البريد الإلكتروني</label>
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>

                        <!-- Phone Number -->
                        <div class="form-floating mb-4">
                            <input asp-for="PhoneNumber" type="tel" class="form-control rounded-3 text-start" placeholder="01xxxxxxxxx" dir="ltr" />
                            <label asp-for="PhoneNumber"><i class="bi bi-phone me-1"></i> رقم الهاتف</label>
                            <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                        </div>

                        <button type="submit" class="btn btn-success w-100 rounded-pill py-2 fw-bold mb-3">
                            تحقق الآن <i class="bi bi-arrow-left ms-1"></i>
                        </button>
                    </form>

                    <div class="text-center mt-4">
                        <a asp-action="Login" class="text-muted text-decoration-none small">
                            <i class="bi bi-arrow-right me-1"></i> العودة لتسجيل الدخول
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<partial name="_ValidationScriptsPartial" />

</body>
</html>
